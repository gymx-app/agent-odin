  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health"
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "PUT Athlete Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sex\": \"male\",\n  \"age\": 32,\n  \"height_cm\": 178,\n  \"current_weight_kg\": 82,\n  \"target_weight_kg\": 74,\n  \"goal\": \"fat_loss\",\n  \"available_days_per_week\": 3,\n  \"session_duration_min\": 45,\n  \"fitness_level\": \"beginner\",\n  \"equipment\": \"full_gym\",\n  \"injuries\": [],\n  \"inbody\": null\n}"
            },
            "url": "{{baseUrl}}/api/profile"
          }
        },
        {
          "name": "PUT Athlete Profile - Unauthorized",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/profile"
          }
        },
        {
          "name": "PUT Athlete Profile - Invalid Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"goal\": \"unknown\"\n}"
            },
            "url": "{{baseUrl}}/api/profile"
          }
        }
      ]
    },
    {
      "name": "Odin",
      "item": [
        {
          "name": "Generate - Deterministic",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.expect([200, 201]).to.include(pm.response.code);",
                  "const json = pm.response.json();",
                  "pm.expect(json.success).to.eql(true);",
                  "pm.collectionVariables.set('programmeId', json.data.programme_id);",
                  "pm.expect(json.data.version).to.eql(1);",
                  "pm.expect(json.data.source).to.eql('deterministic');",
                  "pm.expect(['pass', 'pass_with_warnings']).to.include(json.data.validation.status);",
                  "pm.expect(json.data.refinement.status).to.eql('not_requested');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotencyKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"replace_existing_draft\": false,\n  \"refinement_mode\": \"deterministic\"\n}"
            },
            "url": "{{baseUrl}}/api/odin/generate"
          }
        },
        {
          "name": "Generate - LLM Optional",
          "request": {
            "method": "POST",
