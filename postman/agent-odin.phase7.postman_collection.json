{
  "info": {
    "name": "agent-odin Phase 7",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "programmeId",
      "value": ""
    },
    {
      "key": "idempotencyKey",
      "value": "local-generate-001"
    }
