{
  "info": {
    "name": "agent-odin",
    "description": "Authenticated, stateless programme preview API. Odin does not update athlete profiles or persist generated programmes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "accessToken",
      "value": ""
    }
  ],
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Request ID header exists', function () { pm.expect(pm.response.headers.get('x-request-id')).to.be.a('string').and.not.empty; });",
          "const json = (() => { try { return pm.response.json(); } catch (_) { return null; } })();",
          "if (pm.request.url.getPath() === '/api/health' && pm.response.code === 200) {",
          "  pm.test('Health contract', function () { pm.expect(json.success).to.eql(true); pm.expect(json.data.service).to.eql('agent-odin'); });",
          "}",
          "if (pm.request.url.getPath() === '/api/odin/preview' && pm.response.code === 200) {",
          "  pm.test('Stateless preview contract', function () {",
          "    pm.expect(json.success).to.eql(true);",
          "    pm.expect(['deterministic', 'llm_refined']).to.include(json.data.source);",
          "    pm.expect(['pass', 'pass_with_warnings']).to.include(json.data.validation.status);",
          "    pm.expect(json.data.programme).to.be.an('object');",
          "    pm.expect(json.data).not.to.have.property('programme_id');",
          "    pm.expect(json.data).not.to.have.property('version');",
          "    pm.expect(json.data).not.to.have.property('status');",
          "  });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health"
          }
        }
      ]
    },
    {
      "name": "Programme Preview",
      "item": [
        {
          "name": "Preview - Deterministic",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"athlete\": {\n    \"name\": \"Demo Athlete\",\n    \"age\": 32,\n    \"sex\": \"male\",\n    \"current_weight_kg\": 82,\n    \"target_weight_kg\": 74,\n    \"height_cm\": 178,\n    \"goal\": \"fat_loss\",\n    \"available_days_per_week\": 3,\n    \"session_duration_min\": 45,\n    \"equipment\": \"full_gym\",\n    \"fitness_level\": \"beginner\",\n    \"injuries\": [],\n    \"inbody\": null\n  },\n  \"refinement_mode\": \"deterministic\"\n}"
            },
            "url": "{{baseUrl}}/api/odin/preview"
          }
        },
        {
          "name": "Preview - LLM Optional",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"athlete\": {\n    \"name\": \"Demo Athlete\",\n    \"age\": 32,\n    \"sex\": \"male\",\n    \"current_weight_kg\": 82,\n    \"target_weight_kg\": 74,\n    \"height_cm\": 178,\n    \"goal\": \"fat_loss\",\n    \"available_days_per_week\": 3,\n    \"session_duration_min\": 45,\n    \"equipment\": \"full_gym\",\n    \"fitness_level\": \"beginner\",\n    \"injuries\": [],\n    \"inbody\": null\n  },\n  \"refinement_mode\": \"llm_optional\"\n}"
            },
            "url": "{{baseUrl}}/api/odin/preview"
          }
        },
        {
          "name": "Preview - Missing Auth",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"athlete\":{}}"
            },
            "url": "{{baseUrl}}/api/odin/preview"
          }
        },
        {
          "name": "Preview - Invalid Athlete",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"athlete\":{\"available_days_per_week\":1}}"
            },
            "url": "{{baseUrl}}/api/odin/preview"
          }
        }
      ]
    },
    {
      "name": "Retired Persistence Endpoints",
      "item": [
        {
          "name": "Retired - PUT Athlete Profile",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/profile"
          }
        },
        {
          "name": "Retired - POST Persistent Generate",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/odin/generate"
          }
        },
        {
          "name": "Retired - GET Current Programme",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/programmes/current"
          }
        },
        {
          "name": "Retired - GET Programme by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/programmes/00000000-0000-0000-0000-000000000000"
          }
        }
      ]
    }
  ]
}
