{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci && npm --prefix demo-ui ci",
  "buildCommand": "npm --prefix demo-ui run build",
  "outputDirectory": "demo-ui/dist",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
